// prisma/schema.prisma
// ============================================================
// VERSION 3 — Module Commerce complet
// Ajouts : OrganizationType étendu, Product enrichi,
//          Debt + DebtRepayment, Sale/Stock/Inventory/CashSession
// ============================================================

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// AUTH — Better-Auth compatible
// ============================================================

enum UserRole {
  OWNER
  ADMIN
  ACCOUNTANT
  MEMBER
  CASHIER // caissier — accès limité au POS uniquement
}

model User {
  id          String  @id @default(uuid())
  email       String  @unique
  name        String?
  phoneNumber String? @unique
  password    String?
  image       String?

  emailVerified       Boolean @default(false)
  phoneNumberVerified Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions     Session[]
  accounts     Account[]
  memberships  Membership[]
  cashSessions CashSession[]
}

model Session {
  id        String   @id @default(uuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ipAddress String?
  userAgent String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id         String @id @default(uuid())
  accountId  String
  providerId String

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([providerId, accountId])
  @@index([userId])
}

model Verification {
  id         String   @id @default(uuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
}

// ============================================================
// ORGANISATION & MEMBERSHIP
// ============================================================

// Type d'organisation — conditionne la navigation et les features
enum OrganizationType {
  BUSINESS // Entrepreneur, PME, freelance  → devis + factures
  RETAIL // Épicerie, boutique, magasin   → POS + stock
  RESTAURANT // Restaurant, fast-food, café   → POS + tables
  PHARMACY // Pharmacie                     → POS + péremption
  SALON // Coiffure, beauté, spa         → POS + rendez-vous
  WHOLESALE // Grossiste                     → vente en lot + prix palier
}

model Organization {
  id   String @id @default(uuid())
  slug String @unique

  // name non-unique — deux boutiques peuvent avoir le même nom
  name String
  type OrganizationType @default(BUSINESS)

  defaultCurrency String @default("XOF")

  address String?
  phone   String?
  email   String?
  website String?
  taxId   String?
  logoUrl String?

  // Config caisse
  receiptHeader String? // texte en-tête ticket
  receiptFooter String? // texte pied de ticket (ex: "Merci de votre visite")
  receiptWidth  Int     @default(80) // largeur ticket en mm (58 ou 80)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships       Membership[]
  invoices          Invoice[]
  quotes            Quote[]
  expenses          Expense[]
  clients           Client[]
  vendors           Vendor[]
  expenseCategories ExpenseCategory[]
  productCategories ProductCategory[]
  products          Product[]
  taxRates          TaxRate[]
  subscription      Subscription?
  sales             Sale[]
  cashSessions      CashSession[]
  stockMovements    StockMovement[]
  inventories       Inventory[]
  debts             Debt[]
}

model Membership {
  id String @id @default(uuid())

  userId         String
  organizationId String
  role           UserRole @default(MEMBER)

  createdAt DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
}

// ============================================================
// PLANS & ABONNEMENTS
// ============================================================

enum PlanType {
  FREE
  STARTER
  PRO
  BUSINESS
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  TRIALING
}

model Plan {
  id           String   @id @default(uuid())
  name         PlanType @unique
  priceMonthly Decimal  @db.Decimal(10, 2)
  priceYearly  Decimal  @db.Decimal(10, 2)

  maxInvoices Int?
  maxExpenses Int?
  maxUsers    Int?
  maxProducts Int?
  maxSales    Int? // limite ventes/mois plan commerce

  createdAt DateTime @default(now())

  subscriptions Subscription[]
}

model Subscription {
  id             String @id @default(uuid())
  organizationId String @unique
  planId         String

  status            SubscriptionStatus
  currentPeriodEnd  DateTime
  cancelAtPeriodEnd Boolean            @default(false)
  externalId        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plan         Plan         @relation(fields: [planId], references: [id])
}

// ============================================================
// RÉFÉRENTIELS
// ============================================================

model Currency {
  code   String @id
  name   String
  symbol String
}

model TaxRate {
  id             String @id @default(uuid())
  organizationId String

  name      String
  rate      Decimal @db.Decimal(5, 2)
  isDefault Boolean @default(false)

  createdAt DateTime @default(now())

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoiceItems InvoiceItem[]
  quoteItems   QuoteItem[]

  @@index([organizationId])
}

// Catégorie produit — unique par organisation
model ProductCategory {
  id             String @id @default(uuid())
  organizationId String

  name  String
  color String? // hex ex: "#10b981"
  icon  String? // emoji ex: "🥩"

  createdAt DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  products     Product[]

  // Nom unique par organisation
  @@unique([organizationId, name])
  @@index([organizationId])
}

model Product {
  id             String @id @default(uuid())
  organizationId String

  name        String
  description String?

  // Identification
  sku     String? // référence interne
  barcode String? // code-barres EAN/QR

  // Catégorie — unique par organisation
  categoryId String?
  category   ProductCategory? @relation(fields: [categoryId], references: [id])

  // Prix
  price     Decimal  @db.Decimal(18, 2) // prix de vente
  costPrice Decimal? @db.Decimal(18, 2) // prix d'achat (pour marge)

  // Type
  isService Boolean @default(false)

  // Stock
  currentStock  Decimal  @default(0) @db.Decimal(18, 2)
  minStockAlert Decimal? @db.Decimal(18, 2) // seuil alerte rupture
  unit          String   @default("pcs") // pcs, kg, litre, carton…

  // POS
  isFavorite Boolean @default(false) // épinglé en grille POS
  isActive   Boolean @default(true) // archiver sans supprimer

  // Péremption (pharmacie, alimentation)
  expiryDate DateTime?

  // Legacy
  stockQuantity Decimal? @db.Decimal(18, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoiceItems   InvoiceItem[]
  quoteItems     QuoteItem[]
  saleItems      SaleItem[]
  stockMovements StockMovement[]
  inventoryItems InventoryItem[]

  // SKU unique par organisation (si renseigné)
  @@unique([organizationId, sku])
  @@index([organizationId])
  @@index([organizationId, isActive])
  @@index([organizationId, isFavorite])
  @@index([barcode])
  @@index([organizationId, categoryId])
}

// ============================================================
// CLIENTS & FOURNISSEURS
// ============================================================

enum ClientType {
  INDIVIDUAL
  COMPANY
}

model Client {
  id             String @id @default(uuid())
  organizationId String

  name    String
  email   String?
  phone   String?
  address String?
  city    String?
  country String?
  taxId   String?
  type    ClientType @default(INDIVIDUAL)

  // Fidélité commerce
  loyaltyPoints Int @default(0)

  // Note interne (ex: "client difficile", "paie toujours en retard")
  note String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoices     Invoice[]
  quotes       Quote[]
  sales        Sale[]
  debts        Debt[]

  @@index([organizationId])
  @@index([organizationId, phone])
}

model Vendor {
  id             String @id @default(uuid())
  organizationId String

  name    String
  email   String?
  phone   String?
  address String?
  note    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  expenses       Expense[]
  stockMovements StockMovement[]
  debts          Debt[]

  @@index([organizationId])
}

// ============================================================
// FACTURES
// ============================================================

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  PARTIAL
  OVERDUE
  CANCELLED
}

model Invoice {
  id             String  @id @default(uuid())
  organizationId String
  clientId       String?

  number String
  status InvoiceStatus @default(DRAFT)

  issueDate DateTime
  dueDate   DateTime?

  subtotal Decimal @db.Decimal(18, 2)
  taxTotal Decimal @db.Decimal(18, 2)
  total    Decimal @db.Decimal(18, 2)

  currencyCode String
  exchangeRate Decimal? @db.Decimal(18, 6)

  notes         String?
  terms         String?
  internalNotes String?

  originQuoteId String?
  originQuote   Quote?  @relation("QuoteToInvoice", fields: [originQuoteId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client       Client?       @relation(fields: [clientId], references: [id])
  items        InvoiceItem[]
  payments     Payment[]

  @@unique([organizationId, number])
  @@index([organizationId])
  @@index([clientId])
  @@index([status])
  @@index([organizationId, status])
  @@index([dueDate])
}

model InvoiceItem {
  id        String @id @default(uuid())
  invoiceId String

  name        String
  description String?
  quantity    Decimal @db.Decimal(18, 2)
  unitPrice   Decimal @db.Decimal(18, 2)
  total       Decimal @db.Decimal(18, 2)
  isService   Boolean @default(false)

  taxRateId String?
  taxRate   TaxRate? @relation(fields: [taxRateId], references: [id])

  productId String?
  product   Product? @relation(fields: [productId], references: [id])

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  MOBILE_MONEY
  CARD
  CHECK
  CREDIT // vente à crédit → génère une Debt
  OTHER
}

model Payment {
  id        String @id @default(uuid())
  invoiceId String

  amount Decimal       @db.Decimal(18, 2)
  method PaymentMethod
  paidAt DateTime
  note   String?

  createdAt DateTime @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

// ============================================================
// DEVIS
// ============================================================

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

model Quote {
  id             String  @id @default(uuid())
  organizationId String
  clientId       String?

  number String
  status QuoteStatus @default(DRAFT)

  issueDate  DateTime
  expiryDate DateTime?

  subtotal Decimal @db.Decimal(18, 2)
  taxTotal Decimal @db.Decimal(18, 2)
  total    Decimal @db.Decimal(18, 2)

  currencyCode String
  exchangeRate Decimal? @db.Decimal(18, 6)

  notes         String?
  terms         String?
  internalNotes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client       Client?      @relation(fields: [clientId], references: [id])
  items        QuoteItem[]
  invoices     Invoice[]    @relation("QuoteToInvoice")

  @@unique([organizationId, number])
  @@index([organizationId])
  @@index([clientId])
  @@index([status])
  @@index([organizationId, status])
}

model QuoteItem {
  id      String @id @default(uuid())
  quoteId String

  name        String
  description String?
  quantity    Decimal @db.Decimal(18, 2)
  unitPrice   Decimal @db.Decimal(18, 2)
  total       Decimal @db.Decimal(18, 2)
  isService   Boolean @default(false)

  taxRateId String?
  taxRate   TaxRate? @relation(fields: [taxRateId], references: [id])

  productId String?
  product   Product? @relation(fields: [productId], references: [id])

  quote Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId])
}

// ============================================================
// VENTES POS
// ============================================================

enum SaleStatus {
  COMPLETED // vente finalisée
  REFUNDED // remboursée intégralement
  PARTIAL_REFUND // remboursement partiel
  CANCELLED // annulée avant finalisation
  ON_HOLD // mise en attente (client reviendra)
}

model Sale {
  id             String  @id @default(uuid())
  organizationId String
  clientId       String? // null = client anonyme
  cashSessionId  String? // session de caisse liée

  number String
  status SaleStatus @default(COMPLETED)

  subtotal   Decimal @db.Decimal(18, 2)
  taxTotal   Decimal @db.Decimal(18, 2)
  total      Decimal @db.Decimal(18, 2)
  amountPaid Decimal @db.Decimal(18, 2) // montant encaissé
  change     Decimal @db.Decimal(18, 2) // rendu monnaie
  discount   Decimal @default(0) @db.Decimal(18, 2) // remise globale

  currencyCode String

  // Pour restaurant
  tableNumber String?
  // Note caissier
  note        String?

  // Mode hors-ligne
  isOffline Boolean @default(false)
  offlineId String? // id local généré côté client avant sync

  saleDate  DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client       Client?       @relation(fields: [clientId], references: [id])
  cashSession  CashSession?  @relation(fields: [cashSessionId], references: [id])
  items        SaleItem[]
  payments     SalePayment[]
  // Dette générée si paiement partiel
  debt         Debt?

  @@unique([organizationId, number])
  @@index([organizationId])
  @@index([clientId])
  @@index([cashSessionId])
  @@index([organizationId, saleDate])
  @@index([status])
  @@index([offlineId])
}

model SaleItem {
  id        String  @id @default(uuid())
  saleId    String
  productId String?

  name      String
  quantity  Decimal  @db.Decimal(18, 2)
  unitPrice Decimal  @db.Decimal(18, 2)
  costPrice Decimal? @db.Decimal(18, 2) // snapshot prix achat au moment vente
  discount  Decimal  @default(0) @db.Decimal(18, 2)
  taxRate   Decimal  @default(0) @db.Decimal(5, 2)
  total     Decimal  @db.Decimal(18, 2)

  sale    Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])

  @@index([saleId])
  @@index([productId])
}

model SalePayment {
  id     String @id @default(uuid())
  saleId String

  method PaymentMethod
  amount Decimal       @db.Decimal(18, 2)

  sale Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([saleId])
}

// ============================================================
// STOCK
// ============================================================

enum StockMovementType {
  IN // entrée : achat fournisseur, retour client
  OUT // sortie : vente, don
  ADJUSTMENT // ajustement inventaire
  LOSS // perte, casse, vol
  TRANSFER // transfert entre sites (futur)
}

model StockMovement {
  id             String  @id @default(uuid())
  organizationId String
  productId      String
  vendorId       String?

  type      StockMovementType
  quantity  Decimal           @db.Decimal(18, 2) // toujours positif
  direction Int               @default(1) // +1 entrée / -1 sortie

  unitCost  Decimal? @db.Decimal(18, 2)
  totalCost Decimal? @db.Decimal(18, 2)

  // Référence source
  referenceType String? // "SALE", "INVOICE", "INVENTORY", "MANUAL", "RECEPTION"
  referenceId   String?

  // Lot (pharmacie, alimentation)
  batchNumber String?
  expiryDate  DateTime?

  note      String?
  movedAt   DateTime @default(now())
  createdAt DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  product      Product      @relation(fields: [productId], references: [id])
  vendor       Vendor?      @relation(fields: [vendorId], references: [id])

  @@index([organizationId])
  @@index([productId])
  @@index([organizationId, movedAt])
  @@index([referenceType, referenceId])
}

// ============================================================
// INVENTAIRE
// ============================================================

enum InventoryStatus {
  DRAFT // en cours de comptage
  VALIDATED // validé — ajustements appliqués
  CANCELLED
}

model Inventory {
  id             String @id @default(uuid())
  organizationId String

  name      String
  status    InventoryStatus @default(DRAFT)
  startedAt DateTime        @default(now())
  closedAt  DateTime?
  note      String?

  createdAt DateTime @default(now())

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  items        InventoryItem[]

  @@index([organizationId])
}

model InventoryItem {
  id          String @id @default(uuid())
  inventoryId String
  productId   String

  expectedQty Decimal @db.Decimal(18, 2) // stock théorique
  countedQty  Decimal @db.Decimal(18, 2) // stock réel compté
  variance    Decimal @db.Decimal(18, 2) // countedQty - expectedQty

  note String?

  inventory Inventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id])

  @@unique([inventoryId, productId])
  @@index([inventoryId])
}

// ============================================================
// SESSION DE CAISSE
// ============================================================

enum CashSessionStatus {
  OPEN
  CLOSED
}

model CashSession {
  id             String @id @default(uuid())
  organizationId String
  userId         String

  status   CashSessionStatus @default(OPEN)
  openedAt DateTime          @default(now())
  closedAt DateTime?

  openingBalance  Decimal  @db.Decimal(18, 2)
  closingBalance  Decimal? @db.Decimal(18, 2)
  expectedBalance Decimal? @db.Decimal(18, 2) // calculé auto
  variance        Decimal? @db.Decimal(18, 2) // écart

  note String?

  createdAt DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id])
  sales        Sale[]

  @@index([organizationId])
  @@index([organizationId, status])
}

// ============================================================
// CARNET DE DETTES
// ============================================================

enum DebtType {
  CUSTOMER // crédit accordé à un client (il nous doit)
  SUPPLIER // dette envers un fournisseur (on lui doit)
}

enum DebtStatus {
  OPEN // dette active
  PARTIAL // partiellement remboursée
  SETTLED // soldée
  CANCELLED // annulée
}

model Debt {
  id             String   @id @default(uuid())
  organizationId String
  type           DebtType

  // Lié à un client ou fournisseur enregistré
  clientId String?
  vendorId String?

  // Ou juste un nom + téléphone (sans compte) — très courant terrain
  contactName  String?
  contactPhone String?

  description  String? // note libre : "Riz 25kg + Huile"
  amount       Decimal @db.Decimal(18, 2) // montant total de la dette
  amountPaid   Decimal @default(0) @db.Decimal(18, 2) // déjà remboursé
  currencyCode String  @default("XOF")

  status  DebtStatus @default(OPEN)
  dueDate DateTime? // échéance optionnelle

  // Lien vers la vente ou réception qui a généré la dette
  saleId String? @unique // une vente → au plus une dette
  // note: pas de FK contrainte directe pour éviter la circularité,
  // on gère via referenceType/referenceId si besoin

  note String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client       Client?         @relation(fields: [clientId], references: [id])
  vendor       Vendor?         @relation(fields: [vendorId], references: [id])
  sale         Sale?           @relation(fields: [saleId], references: [id])
  repayments   DebtRepayment[]

  @@index([organizationId])
  @@index([organizationId, type])
  @@index([organizationId, status])
  @@index([organizationId, type, status])
  @@index([clientId])
  @@index([vendorId])
  @@index([dueDate])
}

model DebtRepayment {
  id     String @id @default(uuid())
  debtId String

  amount Decimal       @db.Decimal(18, 2)
  method PaymentMethod @default(CASH)
  note   String?
  paidAt DateTime      @default(now())

  debt Debt @relation(fields: [debtId], references: [id], onDelete: Cascade)

  @@index([debtId])
}

// ============================================================
// DÉPENSES
// ============================================================

model ExpenseCategory {
  id             String  @id @default(uuid())
  organizationId String
  name           String
  color          String?

  createdAt    DateTime     @default(now())
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  expenses     Expense[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

model Expense {
  id             String  @id @default(uuid())
  organizationId String
  vendorId       String?
  categoryId     String

  title       String
  description String?

  subtotal    Decimal  @db.Decimal(18, 2)
  taxAmount   Decimal? @db.Decimal(18, 2)
  totalAmount Decimal  @db.Decimal(18, 2)

  currencyCode String
  exchangeRate Decimal? @db.Decimal(18, 6)

  expenseDate DateTime
  receiptUrl  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  category     ExpenseCategory @relation(fields: [categoryId], references: [id])
  vendor       Vendor?         @relation(fields: [vendorId], references: [id])

  @@index([organizationId])
  @@index([organizationId, expenseDate])
  @@index([categoryId])
}
